{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://sms-server-dgyk.onrender.com/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://sms-server-dgyk.onrender.com/uploads/$1"
    },
    {
      "source": "/:path*",
      "destination": "/index.html",
      "has": [
        {
          "type": "header",
          "key": "Accept",
          "value": ".*text/html.*"
        }
      ]
    }
  ]
}
